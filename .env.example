# ── Environment ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # development | production

# ── Security ──────────────────────────────────────────────────
# In production, set this to your actual domain: https://yourdomain.com
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=60000    # 1 minute window
RATE_LIMIT_MAX=100            # max requests per window

# ── Storage ───────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50           # per-file upload limit
FILE_TTL_MS=3600000           # auto-delete files after 1 hour
CLEANUP_INTERVAL_MS=600000    # run cleanup every 10 minutes
